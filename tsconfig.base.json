{
  "compilerOptions": {
    "target": "es2022",
    "module": "es6",
    "moduleResolution": "Node",
    "lib": ["es2022", "DOM", "DOM.Iterable"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "sourceMap": true,
    "declaration": true,
    "incremental": true
  }
}
