{
    "compilerOptions": {
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "target": "es6",
        "module": "es6",
        "lib": ["es6", "DOM"],
        "baseUrl": ".",
        "paths": {
            "@/*": ["SD/*"],
            "@/sd": ["SD/sd.ts"]
        },
        "strict": false,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "strictFunctionTypes": false,
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "sourceMap": true,
        "declaration": true,
        "declarationDir": "./dist/types",
        "resolveJsonModule": true,
        "incremental": true
    },
    "include": ["SD/**/*", "unit/**/*"],
    "exclude": ["node_modules", "dist", "**/*.spec.ts", "work", "题库"]
}
