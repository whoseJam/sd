{
  "name": "@whosejam/sd-cli",
  "version": "0.0.1",
  "private": true,
  "description": "Build tasks and CLI entry points (sd-animation, sd-animation-group, sd-ppt, sd-config, sd-init)",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "sd-animation": "./dist/animation.js",
    "sd-animation-group": "./dist/animation-group.js",
    "sd-config": "./dist/config.js",
    "sd-init": "./dist/init.js",
    "sd-ppt": "./dist/ppt.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@babel/core": "^7.24.9",
    "@babel/preset-env": "^7.24.8",
    "@babel/preset-typescript": "^7.27.1",
    "@swc/register": "^0.1.10",
    "@whosejam/sd-assets": "workspace:*",
    "@whosejam/sd-core": "workspace:*",
    "@whosejam/sd-element": "workspace:*",
    "@whosejam/sd-impress": "workspace:*",
    "@whosejam/sd-reveal": "workspace:*",
    "@whosejam/sd-webslides": "workspace:*",
    "autoprefixer": "^10.4.19",
    "babel-loader": "^9.1.3",
    "colors-console": "^1.0.3",
    "css-loader": "^7.1.1",
    "gulp-autoprefixer": "^3.1.1",
    "gulp-clean-css": "^4.3.0",
    "gulp-sass": "^5.1.0",
    "gulp-typescript": "^6.0.0-alpha.1",
    "html-webpack-plugin": "^5.6.0",
    "playwright": "^1.49.0",
    "sass": "^1.100.0",
    "sass-loader": "^17.0.0",
    "sharp": "^0.34.0",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.10",
    "through2": "^4.0.2",
    "ts-loader": "^9.5.1",
    "webpack": "^5.92.1",
    "webpack-stream": "^7.0.0"
  },
  "peerDependencies": {
    "gulp": "^5.0.0"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "gulp": "^5.0.0",
    "gulp-strip-comments": "^2.6.0",
    "tsup": "^8.5.1"
  }
}
