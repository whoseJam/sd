{
  "name": "@whosejam/sd-core",
  "version": "0.0.1",
  "private": false,
  "description": "SD rendering engine (Animate / Node / Renderer / Math / Utility / Interact). Layout helpers live in @whosejam/sd-layout.",
  "homepage": "https://github.com/whoseJam/sd/tree/master/packages/core",
  "bugs": "https://github.com/whoseJam/sd/issues",
  "license": "ISC",
  "author": "whoseJam",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whoseJam/sd.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/sd.js",
  "types": "./dist/sd.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/sd.d.ts",
      "default": "./dist/sd.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@flatten-js/core": "^1.6.2",
    "opentype.js": "^1.3.4"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/opentype.js": "^1.3.8",
    "happy-dom": "^20.9.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.7"
  }
}
