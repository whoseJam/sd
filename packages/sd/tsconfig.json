{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@whosejam/sd-core": ["../core/src/sd.ts"],
      "@whosejam/sd-core/*": ["../core/src/*"],
      "@whosejam/sd-layout": ["../layout/src/index.ts"],
