{
  "name": "@whosejam/sd",
  "version": "0.0.1",
  "private": true,
  "description": "Public entry: re-exports @whosejam/sd-core flat and the layout() factory from @whosejam/sd-layout.",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@whosejam/sd-core": "workspace:*",
    "@whosejam/sd-layout": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
