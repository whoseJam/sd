{
  "name": "@whosejam/sd-element",
  "version": "0.0.1",
  "private": false,
  "description": "<sd-animation> custom element. Host page loads this once; embeds animations via <sd-animation src=...>.",
  "homepage": "https://github.com/whoseJam/sd/tree/master/packages/element",
  "bugs": "https://github.com/whoseJam/sd/issues",
  "license": "ISC",
  "author": "whoseJam",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whoseJam/sd.git",
    "directory": "packages/element"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/element.js",
  "types": "./dist/element.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/element.d.ts",
      "default": "./dist/element.js"
    },
    "./template.html": "./dist/template.html"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
