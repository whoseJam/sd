{
  "name": "@whosejam/sd-element",
  "version": "0.0.1",
  "private": true,
  "description": "<sd-animation> custom element. Host page loads this once; embeds animations via <sd-animation src=...>.",
  "license": "ISC",
  "type": "module",
  "main": "./dist/element.js",
  "types": "./dist/element.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/element.d.ts",
      "default": "./dist/element.js"
    },
    "./template.html": "./dist/template.html"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
