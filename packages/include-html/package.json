{
  "name": "@whosejam/sd-include-html",
  "version": "0.0.1",
  "private": true,
  "description": "DOM walker that resolves <... include-html=\"./xxx.html\"> attributes by fetching and inlining the referenced HTML",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
