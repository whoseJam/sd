{
  "name": "@whosejam/sd-include-html",
  "version": "0.0.1",
  "private": false,
  "description": "DOM walker that resolves <... include-html=\"./xxx.html\"> attributes by fetching and inlining the referenced HTML",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whoseJam/sd.git",
    "directory": "packages/include-html"
  },
  "homepage": "https://github.com/whoseJam/sd/tree/master/packages/include-html",
  "bugs": "https://github.com/whoseJam/sd/issues",
  "author": "whoseJam"
}
