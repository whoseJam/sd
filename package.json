{
  "name": "sd-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root — not published. See packages/sd for the public entry.",
  "license": "ISC",
  "browser": {
    "fs": false,
    "path": false,
    "os": false
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "format": "oxfmt && oxlint --fix",
    "lint": "oxlint",
    "check:format": "oxfmt --check",
    "check:lint": "oxlint",
    "start": "bun packages/cli/src/serve.ts start",
    "stop": "bun packages/cli/src/serve.ts stop",
    "open": "bun packages/cli/src/view.ts show",
    "close": "bun packages/cli/src/view.ts hide",
    "snap": "bun packages/cli/src/snap.ts"
  },
  "devDependencies": {
    "@svgdotjs/svg.js": "^3.2.0",
    "@swc/core": "^1.15.40",
    "@swc/register": "^0.1.10",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "gulp": "^5.0.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.58.0",
    "tsup": "^8.5.1",
    "typescript": "^5.5.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
