{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "jsPlugins": ["eslint-plugin-perfectionist"],
  "categories": {
    "correctness": "off"
  },
  "env": {
    "builtin": true,
    "browser": true,
    "node": true
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "packages/assets/**",
    "packages/reveal/src/plugin/HighlightEngine.js",
    "ppt/**",
    "__deprecated__/**"
  ],
  "rules": {
    "perfectionist/sort-imports": [
      "error",
      { "type": "natural", "order": "asc" }
    ]
  },
  "overrides": [
    {
      "files": ["**/*.ts", "**/*.tsx"],
      "rules": {
        "@typescript-eslint/consistent-type-imports": "error"
      }
    },
    {
      "files": ["**/*.js", "**/*.ts", "**/*.tsx", "**/*.mjs", "**/*.cjs"],
      "rules": {
        "no-unused-vars": "warn"
      }
    }
  ]
}
